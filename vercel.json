{
  "version": 2,
  "buildCommand": "pnpm install && pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "client/dist",
  "public": false,
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "@vite_api_url"
  },
  "envPrefix": "VITE_",
  "regions": ["sfo1"],
  "functions": {
    "server/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.example.com/:path*"
    }
  ]
}
